@{
    Layout = "User_layout";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<style>
    body {
        /* Old: background: linear-gradient(135deg, #667eea, #764ba2); */
        background: linear-gradient(135deg, #a8edea, #fed6e3); /* light, soft gradient */
        min-height: 100vh;
    }

    .dashboard-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 85vh;
        text-align: center;
        color: white;
    }

    .welcome-box {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(12px);
        border-radius: 25px;
        padding: 60px 40px;
        max-width: 700px;
        width: 100%;
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }

    .dash-btn {
        margin-top: 30px;
        padding: 12px 35px;
        border-radius: 50px;
        border: none;
        font-weight: 600;
        background: linear-gradient(45deg, #ff416c, #ff4b2b);
        color: white;
        transition: 0.3s;
    }

        .dash-btn:hover {
            transform: scale(1.08);
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }
</style>

<div class="dashboard-container">
    <div class="welcome-box animate__animated animate__zoomIn">

        <h1 class="animate__animated animate__fadeInDown">
            👋 Hello, Welcome to Your Dashboard
        </h1>

        <p class="mt-3 animate__animated animate__fadeInUp">
            Manage your profile, explore categories and enjoy shopping.
        </p>

        <a href="/User/Category"
           class="btn dash-btn animate__animated animate__pulse animate__infinite">
            🚀 Explore Now
        </a>

    </div>
</div>