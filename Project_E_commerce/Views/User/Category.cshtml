@{
    Layout = "User_layout";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="~/lib/jquery/dist/jquery.min.js"></script>

<style>
    .category-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        position: relative;
        transition: 0.4s;
        cursor: pointer;
    }

        .category-card img {
            height: 220px;
            object-fit: cover;
            transition: 0.4s;
        }

        .category-card:hover img {
            transform: scale(1.1);
        }

    .overlay {
        position: absolute;
        bottom: 0;
        width: 100%;
        background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
        padding: 20px;
        color: white;
    }

    .explore-btn {
        background: linear-gradient(45deg, #ff416c, #ff4b2b);
        border: none;
        border-radius: 30px;
        padding: 8px 18px;
        color: white;
        font-size: 14px;
        transition: 0.3s;
    }

        .explore-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 15px rgba(0,0,0,0.3);
        }
</style>

<h3 class="text-center fw-bold mb-4">✨ Explore Categories</h3>

<div class="container">
    <div class="row" id="categoryContainer"></div>
</div>

<script>
    $(document).ready(function () {

        $.ajax({
            url: "/api/AuthApi/GetCategories",
            type: "GET",
            success: function (res) {

                $("#categoryContainer").empty();

                $.each(res, function (i, item) {

                    $("#categoryContainer").append(`
                        <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                            <div class="card category-card shadow-sm">

                                <img src="${item.imagepath}" class="card-img-top">

                                <div class="overlay text-center">
                                    <h5 class="fw-bold">${item.categoryName}</h5>
                                    <button class="btn explore-btn mt-2"
                                            onclick="openCategory(${item.categoryId})">
                                        🔍 Explore Category
                                    </button>
                                </div>

                            </div>
                        </div>
                    `);

                });
            }
        });

    });

    function openCategory(id) {
        window.location.href = "/User/Products/" + id;
    }
</script>