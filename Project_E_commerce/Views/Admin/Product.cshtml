@{
    Layout = "Admin_layout";
    var categoryId = ViewBag.CategoryId;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container mt-4">

    <h3 class="mb-4 text-primary fw-bold">Products</h3>
    <div class="row g-4" id="productContainer"></div>

    <!-- ================= PRODUCT GRAPHS ================= -->
    <h3 class="mb-4 text-primary fw-bold mt-5">Analytics</h3>
    <div class="row g-4 justify-content-center">

        <!-- Price Distribution (Bar Chart) -->
        <div class="col-md-5">
            <div class="card shadow-sm rounded-4 p-3" style="height:320px; display:flex; flex-direction:column; justify-content:center;">
                <h5 class="fw-bold mb-3 text-center">Price Distribution</h5>
                <canvas id="priceChart" style="max-height:250px;"></canvas>
            </div>
        </div>

        <!-- Products Count by Price Range (Pie Chart) -->
        <div class="col-md-5">
            <div class="card shadow-sm rounded-4 p-3" style="height:320px; display:flex; flex-direction:column; justify-content:center; align-items:center;">
                <h5 class="fw-bold mb-3 text-center">Products by Price Range</h5>
                <canvas id="priceRangeChart" style="max-height:250px; max-width:250px;"></canvas>
            </div>
        </div>

    </div>

</div>

<!-- ================= EDIT MODAL ================= -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Update Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="editProductId" />

                <div class="mb-3">
                    <label>Product Name</label>
                    <input type="text" id="editProductName" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Price</label>
                    <input type="number" id="editPrice" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Image</label>
                    <input type="file" id="editImage" class="form-control" />
                </div>

                <div class="text-center mt-2">
                    <img id="previewImage" style="width:120px;height:120px;object-fit:cover;border-radius:10px;" />
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" onclick="updateProduct()">Update</button>
            </div>

        </div>
    </div>
</div>

<script>
    var categoryId = "@categoryId";
    var priceChart, priceRangeChart;

    $(document).ready(function () {
        loadProducts();
    });

    // ================= LOAD PRODUCTS =================
    function loadProducts() {
        $.get("/api/AuthApi/GetProductsByCategory/" + categoryId, function (res) {
            $("#productContainer").empty();

            if (res.length === 0) {
                $("#productContainer").html("<h5>No Products Found</h5>");
                renderCharts([]);
                return;
            }

            $.each(res, function (i, item) {
                $("#productContainer").append(`
                    <div class="col-md-3">
                        <div class="card shadow-sm">
                            <img src="${item.imagepath}" class="card-img-top" style="height:200px;object-fit:cover">
                            <div class="card-body text-center">
                                <h6>${item.productname}</h6>
                                <p class="text-success fw-bold">₹ ${item.price}</p>
                                <button class="btn btn-warning btn-sm" onclick="openEditModal(${item.product_id})">Edit</button>
                                <button class="btn btn-danger btn-sm" onclick="deleteProduct(${item.product_id})">Delete</button>
                            </div>
                        </div>
                    </div>
                `);
            });

            renderCharts(res);
        });
    }

    // ================= OPEN MODAL + PREFILL =================
    function openEditModal(id) {
        $.get("/api/AuthApi/GetProductById/" + id, function (data) {
            $("#editProductId").val(data.product_id);
            $("#editProductName").val(data.productname);
            $("#editPrice").val(data.price);
            $("#previewImage").attr("src", data.imagepath);
            var modal = new bootstrap.Modal(document.getElementById("editModal"));
            modal.show();
        });
    }

    // ================= IMAGE PREVIEW =================
    $("#editImage").change(function () {
        if (this.files && this.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) { $("#previewImage").attr("src", e.target.result); };
            reader.readAsDataURL(this.files[0]);
        }
    });

    // ================= UPDATE PRODUCT =================
    function updateProduct() {
        var formData = new FormData();
        formData.append("product_id", parseInt($("#editProductId").val()));
        formData.append("ProductName", $("#editProductName").val());
        formData.append("Price", $("#editPrice").val());
        formData.append("CategoryId", categoryId);

        var file = $("#editImage")[0].files[0];
        if (file) { formData.append("Image", file); }
        else { formData.append("ImagePath", $("#previewImage").attr("src")); }

        $.ajax({
            url: "/api/AuthApi/UpdateProduct",
            type: "POST",
            data: formData,
            contentType: false,
            processData: false,
            success: function () {
                Swal.fire({ icon: 'success', title: 'Updated Successfully!', timer: 1500, showConfirmButton: false });
                var modal = bootstrap.Modal.getInstance(document.getElementById("editModal"));
                modal.hide();
                loadProducts();
            },
            error: function (err) {
                Swal.fire({ icon: 'error', title: 'Update Failed!', text: err.responseText });
            }
        });
    }

    // ================= DELETE PRODUCT =================
    function deleteProduct(id) {
        Swal.fire({
            title: 'Are you sure?',
            text: "This product will be permanently deleted!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Yes, delete it!'
        }).then((result) => {
            if (result.isConfirmed) {
                $.post("/api/AuthApi/DeleteProduct/" + id, function () {
                    Swal.fire({ icon: 'success', title: 'Deleted Successfully!', timer: 1500, showConfirmButton: false });
                    loadProducts();
                });
            }
        });
    }

    // ================= RENDER CHARTS =================
    function renderCharts(products) {

        // ---------------- Price Distribution Chart ----------------
        const labels = products.map(p => p.productname);
        const data = products.map(p => p.price);
        const bgColors = products.map(() => `hsl(${Math.random()*360}, 70%, 60%)`);

        if (priceChart) priceChart.destroy();

        priceChart = new Chart(document.getElementById('priceChart'), {
            type: 'bar',
            data: { labels: labels, datasets: [{ label: 'Price (₹)', data: data, backgroundColor: bgColors }] },
            options: { responsive: true, plugins: { legend: { display: false }, title: { display: true, text: 'Price Distribution' } } }
        });

        // ---------------- Products by Price Range Chart ----------------
        const priceRanges = { Low: 0, Medium: 0, High: 0 };
        products.forEach(p => {
            if (p.price < 500) priceRanges.Low++;
            else if (p.price < 2000) priceRanges.Medium++;
            else priceRanges.High++;
        });

        const priceRangeCanvas = document.getElementById('priceRangeChart');
        if (priceRangeChart) priceRangeChart.destroy();

        priceRangeChart = new Chart(priceRangeCanvas, {
            type: 'pie',
            data: {
                labels: Object.keys(priceRanges),
                datasets: [{
                    data: Object.values(priceRanges),
                    backgroundColor: ['rgba(75,192,192,0.7)','rgba(255,206,86,0.7)','rgba(255,99,132,0.7)']
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false, // charts smaller than card
                plugins: { legend: { position: 'bottom' }, title: { display: true, text: 'Products by Price Range' } }
            }
        });
    }
</script>