@{
    Layout = "Admin_layout";
    var categoryId = ViewBag.CategoryId;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="~/lib/jquery/dist/jquery.min.js"></script>

<h3 class="mb-4 text-primary fw-bold">Products</h3>

<div class="row g-4" id="productContainer"></div>

<script>
    $(document).ready(function () {

        var categoryId = "@categoryId";

        $.ajax({
            url: "/api/AuthApi/GetProductsByCategory/" + categoryId,
            type: "GET",
            success: function (res) {

                $("#productContainer").empty();

                if(res.length == 0){
                    $("#productContainer").html("<h5 class='text-muted text-center'>No Products Found</h5>");
                    return;
                }

                $.each(res, function (i, item) {

                    $("#productContainer").append(`
                        <div class="col-lg-3 col-md-4 col-sm-6">
                            <div class="card product-card h-100 shadow-sm rounded-4 overflow-hidden">

                                <div class="card-img-wrapper position-relative">
                                    <img src="${item.imagepath}"
                                         class="card-img-top img-fluid"
                                         alt="${item.productname}">
                                    <div class="overlay d-flex justify-content-center align-items-center">
                                        <i class="bi bi-eye-fill text-white fs-2"></i>
                                    </div>
                                </div>

                                <div class="card-body text-center">
                                    <h6 class="fw-semibold mb-2">${item.productname}</h6>
                                    <p class="text-success fw-bold mb-0">₹ ${item.price}</p>
                                </div>
                            </div>
                        </div>
                    `);

                });
            }
        });

    });
</script>

<style>
    body {
        background-color: #f8f9fa;
    }

    .product-card {
        transition: transform 0.3s, box-shadow 0.3s;
        cursor: pointer;
    }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 25px rgba(0, 0, 0, 0.15);
        }

    .card-img-wrapper {
        position: relative;
        overflow: hidden;
    }

    .card-img-top {
        height: 200px;
        object-fit: cover;
        transition: transform 0.3s;
    }

    .product-card:hover .card-img-top {
        transform: scale(1.05);
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.2);
        opacity: 0;
        transition: opacity 0.3s;
    }

    .product-card:hover .overlay {
        opacity: 1;
    }

    .card-body h6 {
        color: #343a40;
        font-size: 1rem;
    }

   
</style>