@{
    Layout = "Admin_layout";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container mt-4">

    <h3 class="mb-4 text-primary fw-bold">All Categories</h3>

    <div class="row g-4" id="categoryContainer"></div>

</div>

<script>

    $(document).ready(function () {
        loadCategories();
    });

    function loadCategories() {

        $.ajax({
            url: "/api/AuthApi/GetCategories",
            type: "GET",
            success: function (res) {

                $("#categoryContainer").empty();

                $.each(res, function (i, item) {

                    $("#categoryContainer").append(`
                        <div class="col-lg-3 col-md-4 col-sm-6">
                            <div class="card category-card shadow-sm rounded-4 overflow-hidden">

                                <div class="card-img-wrapper position-relative"
                                     onclick="openCategory(${item.categoryId})">

                                    <img src="${item.imagepath}"
                                         class="card-img-top img-fluid"
                                         alt="${item.categoryName}">

                                    <div class="overlay d-flex justify-content-center align-items-center">
                                        <span class="text-white fw-bold">View</span>
                                    </div>

                                    <div class="action-buttons">
                                        <button class="btn btn-sm btn-light"
                                            onclick="event.stopPropagation(); editCategory(${item.categoryId}, '${item.categoryName}', '${item.imagepath}')">
                                            ✏
                                        </button>

                                        <button class="btn btn-sm btn-danger"
                                            onclick="event.stopPropagation(); deleteCategory(${item.categoryId})">
                                            🗑
                                        </button>
                                    </div>

                                </div>

                                <div class="card-body text-center">
                                    <h5 class="fw-bold">${item.categoryName}</h5>
                                </div>

                            </div>
                        </div>
                    `);
                });
            }
        });
    }

  
    function openCategory(id) {
        window.location.href = "/Admin/Product/" + id;
    }

    function editCategory(id, oldName, oldImage) {

        Swal.fire({
            title: 'Edit Category',
            html: `
                <input type="text" id="swalCategoryName" class="swal2-input"
                       value="${oldName}" placeholder="Category Name">

                <input type="file" id="swalCategoryImage" class="swal2-file">

                <img src="${oldImage}"
                     style="width:100px;height:100px;margin-top:10px;border-radius:10px;"
                     id="previewImage">
            `,
            showCancelButton: true,
            confirmButtonText: 'Update',
            preConfirm: () => {

                let name = document.getElementById("swalCategoryName").value;
                let file = document.getElementById("swalCategoryImage").files[0];

                if (!name) {
                    Swal.showValidationMessage("Category name is required");
                    return false;
                }

                return { name: name, file: file };
            }
        }).then((result) => {

            if (result.isConfirmed) {

                var formData = new FormData();
                formData.append("categoryId", id);
                formData.append("categoryName", result.value.name);

                if (result.value.file != null) {
                    formData.append("image", result.value.file);
                }

                $.ajax({
                    url: '/api/AuthApi/UpdateCategory',
                    type: 'POST',
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function () {

                        Swal.fire({
                            icon: 'success',
                            title: 'Updated Successfully!',
                            timer: 1500,
                            showConfirmButton: false
                        });

                        loadCategories();
                    }
                });
            }
        });

       
        $(document).on("change", "#swalCategoryImage", function () {
            let reader = new FileReader();
            reader.onload = function (e) {
                $("#previewImage").attr("src", e.target.result);
            }
            reader.readAsDataURL(this.files[0]);
        });
    }

    // ================= DELETE CATEGORY =================
    function deleteCategory(id) {

        Swal.fire({
            title: 'Are you sure?',
            text: "This category will be permanently deleted!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            confirmButtonText: 'Yes, delete it!'
        }).then((result) => {

            if (result.isConfirmed) {
                debugger
                $.ajax({
                    url: '/api/AuthApi/DeleteCategory',
                    type: 'POST',
                    data: { id: id },
                    success: function () {
                        console.log("czx",id)

                        Swal.fire({
                            icon: 'success',
                            title: 'Deleted Successfully!',
                            timer: 1500,
                            showConfirmButton: false
                        });

                        loadCategories();
                    }
                });
            }
        });
    }

</script>

<style>

    body {
        background-color: #f8f9fa;
    }

    .category-card {
        transition: 0.3s;
        cursor: pointer;
    }

        .category-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.15);
        }

    .card-img-wrapper {
        position: relative;
        overflow: hidden;
    }

    .card-img-top {
        height: 200px;
        object-fit: cover;
        transition: 0.3s;
    }

    .category-card:hover .card-img-top {
        transform: scale(1.05);
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.4);
        opacity: 0;
        transition: 0.3s;
    }

    .category-card:hover .overlay {
        opacity: 1;
    }

    .action-buttons {
        position: absolute;
        top: 10px;
        right: 10px;
        display: flex;
        gap: 5px;
    }

        .action-buttons button {
            border-radius: 50%;
            width: 32px;
            height: 32px;
            padding: 0;
            font-size: 14px;
        }

</style>