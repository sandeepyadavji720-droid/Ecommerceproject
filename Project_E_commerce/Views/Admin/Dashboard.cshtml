@{
    Layout = "Admin_layout";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="~/lib/jquery/dist/jquery.min.js"></script>

<h3 class="mb-4 text-primary fw-bold">All Categories</h3>

<div class="row g-4" id="categoryContainer"></div>

<script>
    $(document).ready(function () {

        $.ajax({
            url: "/api/AuthApi/GetCategories",
            type: "GET",
            success: function (res) {
                $("#categoryContainer").empty();

                $.each(res, function (i, item) {
                    $("#categoryContainer").append(`
                        <div class="col-lg-3 col-md-4 col-sm-6">
                            <div class="card category-card h-100 shadow-sm rounded-4 overflow-hidden"
                                 onclick="openCategory(${item.categoryId})">

                                <div class="card-img-wrapper position-relative">
                                    <img src="${item.imagepath}"
                                         class="card-img-top img-fluid"
                                         alt="${item.categoryName}">
                                    <div class="overlay d-flex justify-content-center align-items-center">
                                        <i class="bi bi-eye-fill text-white fs-2"></i>
                                    </div>
                                </div>

                                <div class="card-body text-center">
                                    <h5 class="card-title fw-bold">${item.categoryName}</h5>
                                </div>
                            </div>
                        </div>
                    `);
                });
            }
        });

    });

    function openCategory(id) {
        window.location.href = "/Admin/Product/" + id;
    }
</script>

<style>
    body {
        background-color: #f8f9fa;
    }

    .category-card {
        transition: transform 0.3s, box-shadow 0.3s;
        cursor: pointer;
    }

        .category-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 25px rgba(0, 0, 0, 0.15);
        }

    .card-img-wrapper {
        position: relative;
        overflow: hidden;
    }

    .card-img-top {
        height: 200px;
        object-fit: cover;
        transition: transform 0.3s;
    }

    .category-card:hover .card-img-top {
        transform: scale(1.05);
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.3);
        opacity: 0;
        transition: opacity 0.3s;
    }

    .category-card:hover .overlay {
        opacity: 1;
    }

    .card-title {
        color: #343a40;
        font-size: 1.1rem;
    }

   
</style>