@{
    Layout = "Admin_layout";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    #formCard {
        transition: all 0.5s ease;
    }

    .success-message {
        display: none;
        text-align: center;
        padding: 40px;
        background: #f8fff8;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-8">

            <!-- FORM CARD -->
            <div class="card shadow-lg p-4 rounded-4" id="formCard">
                <h4 class="text-center text-primary mb-4">Add Product</h4>

                <form id="productForm" method="post" enctype="multipart/form-data">

                    <!-- Product Name -->
                    <div class="mb-3">
                        <label>Product Name</label>
                        <input type="text" name="productname"
                               class="form-control form-control-lg"
                               required />
                    </div>

                    <!-- Price -->
                    <div class="mb-3">
                        <label>Price</label>
                        <input type="number" name="price"
                               class="form-control form-control-lg"
                               required />
                    </div>

                    <!-- Category Dropdown -->
                    <div class="mb-3">
                        <label>Select Category</label>
                        <select name="categoryId"
                                id="categoryDropdown"
                                class="form-select form-select-lg"
                                required>
                            <option value="">-- Select Category --</option>
                        </select>
                    </div>

                    <!-- Image -->
                    <div class="mb-4">
                        <label>Product Image</label>
                        <input type="file" name="image"
                               class="form-control form-control-lg"
                               accept="image/*"
                               required />
                    </div>

                    <div class="d-grid">
                        <button type="submit"
                                id="submitBtn"
                                class="btn btn-primary btn-lg">
                            Save Product
                        </button>
                    </div>

                </form>
            </div>

            <!-- SUCCESS MESSAGE -->
            <div class="success-message mt-4" id="successMessage">
                <h4 class="text-success">✅ Product Added Successfully!</h4>
                <button class="btn btn-outline-primary mt-3" onclick="showFormAgain()">
                    Add Another Product
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    $(document).ready(function () {

        // Load Categories
        $.ajax({
            url: "/api/AuthApi/GetCategories",
            type: "GET",
            success: function (res) {

                $("#categoryDropdown").empty();
                $("#categoryDropdown").append('<option value="">-- Select Category --</option>');

                $.each(res, function (i, item) {
                    $("#categoryDropdown").append(
                        '<option value="' + item.categoryId + '">' + item.categoryName + '</option>'
                    );
                });
            }
        });

        // Submit Form
        $("#productForm").submit(function (e) {

            e.preventDefault();

            var formData = new FormData(this);

            $("#submitBtn").prop("disabled", true).html("Saving...");

            $.ajax({
                url: "/api/AuthApi/AddProduct",
                type: "POST",
                data: formData,
                contentType: false,
                processData: false,

                success: function (res) {

                    Swal.fire({
                        icon: 'success',
                        title: 'Product Added!',
                        text: 'Product saved successfully.',
                        timer: 1500,
                        showConfirmButton: false
                    });

                    setTimeout(function () {

                        // Slide Up Form
                        $("#formCard").slideUp(600, function () {

                            // Show Success Card
                            $("#successMessage").fadeIn(500);

                        });

                    }, 1200);

                },

                error: function (res) {

                    Swal.fire({
                        icon: 'error',
                        title: 'Error!',
                        text: 'Failed to save product.'
                    });

                    $("#submitBtn").prop("disabled", false).html("Save Product");
                }
            });

        });

    });

    // Show form again
    function showFormAgain() {

        $("#productForm")[0].reset();

        $("#successMessage").hide();

        $("#formCard").slideDown(600);

        $("#submitBtn").prop("disabled", false).html("Save Product");
    }
</script>